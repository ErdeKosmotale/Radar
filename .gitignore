# ============================================================
#  민감정보 — RFP III-5-나
#  API 키·DB 경로·인증정보를 소스코드/GitHub에 기재하는 것 절대 금지.
#  위반 시 미완료 처리 대상.
# ============================================================
.env
.env.*
!.env.example
/radar_impement/.env

# 혹시 모를 키 파일들
*.pem
*.key
secrets.json


# ============================================================
#  ⚠️  local.db 는 일부러 ignore 하지 않는다
#
#  RFP III-6-나: 백엔드는 Render 로 "repo 연동 배포".
#  local.db 를 gitignore 하면 Render 서버에 DB가 없어서 앱이 죽는다.
#  또 산출물 목록에 "SQLite DB 파일(.db) — 초기 데이터 포함" 이 있다.
#
#  단, Render 무료 티어는 파일시스템이 비영속이라 런타임에 쌓인
#  제보는 재시작 시 사라진다. 시연용 제보는 커밋된 .db 안에 미리 넣어둘 것.
# ============================================================
# local.db   ← 주석 유지! 풀지 말 것


# ---------- Python ----------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- 에디터 ----------
.vscode/
.idea/
*.swp

# ---------- OS ----------
.DS_Store
Thumbs.db
